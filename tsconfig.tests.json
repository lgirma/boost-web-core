{
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules/*",
    "__sapper__/*",
    "dist/*"
  ],
  "compilerOptions": {
    "baseUrl": "src",
    "resolveJsonModule": true,
    "importsNotUsedAsValues": "remove",
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "es2017",
    "isolatedModules": true,
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "src"
  }
}