{
  "name": "@boost-web/core",
  "version": "1.27.0",
  "description": "Web development utilities base",
  "module": "dist/index.esm.js",
  "main": "dist/index.cjs.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "ts-mocha -p ./tsconfig.tests.json 'tests/**/*.ts'",
    "buildEsbuild": "node ./esbuild.config.js",
    "typedecs": "tsc -p tsconfig.typedec.json --emitDeclarationOnly",
    "release": "bash ./release.sh",
    "devEsbuild": "cross-env WATCH=1 node ./esbuild.config.js",
    "start": "sirv dist",
    "validate": "svelte-check"
  },
  "author": "Lee",
  "license": "ISC",
  "repository": "https://github.com/lgirma/boost-web-core",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^17.1.0",
    "@rollup/plugin-node-resolve": "^11.2.0",
    "@rollup/plugin-typescript": "^8.2.0",
    "@types/chai": "^4.2.15",
    "@types/mocha": "^8.2.0",
    "@types/node": "^14.14.28",
    "chai": "^4.3.0",
    "chai-spies": "^1.0.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.8.49",
    "mocha": "^8.3.0",
    "mockery": "^2.1.0",
    "sirv-cli": "^1.0.0",
    "ts-mocha": "^8.0.0",
    "ts-node": "^9.1.1",
    "tslib": "^2.0.0",
    "typescript": "^4.0.0",
    "uuid": "^8.3.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "registry": "http://localhost:4873"
  }
}
